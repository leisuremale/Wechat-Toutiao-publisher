{
  "obsidian_vault": "/Users/your-username/Library/Mobile Documents/iCloud~md~obsidian/Documents/YourVault",
  "queue_dir": "AI写作/待发文章",
  "published_dir": "AI写作/已发布文章",
  "toutiao_dir": "/Users/your-username/output/头条待发",

  "wechat": {
    "theme_css": "themes/mo-ping.css",
    "author": "墨言"
  },

  "cover": {
    "template": "literary",
    "width": 900,
    "height": 500,
    "subtitle": "墨 言 书 评",
    "templates_dir": null
  },

  "wenyan_bin": null,

  "toutiao": {
    "auto": false,
    "user_data_dir": null,
    "headless": true,
    "screenshot_dir": null,
    "timeout_ms": 60000,
    "selectors": {}
  },

  "retry": {
    "wechat_attempts": 3,
    "toutiao_attempts": 2,
    "base_delay": 2.0,
    "max_delay": 30.0
  },

  "notify": {
    "webhook_url": null,
    "osascript": false
  },

  "log": {
    "dir": null,
    "level": "INFO"
  },

  "illustrate": {
    "book_cover": {
      "enabled": true,
      "sources": ["dangdang", "douban", "google_books"],
      "cache_dir": null,
      "timeout": 10
    },
    "quote_cards": {
      "enabled": true,
      "template": "classic",
      "templates_dir": null,
      "min_chars": 15,
      "max_per_article": 4
    },
    "stock_images": {
      "enabled": false,
      "source": "pexels",
      "fallback": "wikimedia",
      "api_key": null,
      "default_keywords": [
        "library", "books", "reading", "vintage", "candlelight",
        "writing", "manuscript", "old paper", "quiet", "bookshelf"
      ],
      "count_per_article": 3,
      "min_chars_per_image": 600,
      "license_attribution": true,
      "cache_dir": null,
      "timeout": 15
    }
  }
}
